https://leetcode.com/problems/sort-characters-by-frequency/

class Solution {
    public String frequencySort(String s) {
        HashMap<Character,Integer> mpp = new HashMap<>();               
        StringBuilder ans = new StringBuilder();
        for(int i = 0 ; i < s.length() ; i ++){
            mpp.put(s.charAt(i),mpp.getOrDefault(s.charAt(i),0)+1);       //Making hashmap of input string characters as keys and their frequency as value of type INteger
        }
        List<Character> list = new ArrayList<>(mpp.keySet());             // mamking list of keysets of hashmap ie characters in input string s
        Collections.sort(list,(a,b)-> mpp.get(b)-mpp.get(a));             // sorting of mappings based on frequencies.

        for(int i = 0 ;i < list.size() ;i++){                             //simply putting character first that has high frequency 
            int freq = mpp.get(list.get(i));
            for(int j = 0; j < freq ; j++){
                ans.append(list.get(i));
            }
        }
       return ans.toString();                                            // converting stringbuilder into string to return ans.

        


    }
}
