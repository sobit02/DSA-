//https://leetcode.com/problems/longest-common-prefix/

class Solution {
    public String longestCommonPrefix(String[] strs) {
        Arrays.sort(strs);                                // sorting creates the maximum difference in first and last string 
        String first = strs[0];
        String last = strs[strs.length-1];
        
        int i = 0;
        while(i<first.length() && i<last.length() && first.charAt(i)==last.charAt(i)){              //comparing only first and last strings each character 
            i++;
        }
        return first.substring(0,i);                                                   // can return last.substring(0,i)
       
    }
    
}
