// https://leetcode.com/problems/reverse-words-in-a-string/
//i solved it  using go language because i have been learning go in backgroud

func reverseWords(s string) string {
    words := strings.Fields(s)                 //creates a array of string using spaces as separator in string s
    ans:=""
    for i:=len(words)-1;i>=0;i--{
        ans=ans+words[i]
        if (i!=0)  {ans = ans + " "}
    }
    return ans;
}
